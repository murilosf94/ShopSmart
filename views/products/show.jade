//- views/products/show.jade
extends ../layout

block content
  .products-section
    .container
      .product-card
        .product-image-container(style="height: 600px;")
          if product.imageUrl
            img.product-image(src=product.imageUrl, alt=product.name)
          else
            .product-placeholder
              .placeholder-icon 📷
              span Sem imagem

        .product-content
          h1.product-title= product.name

          .product-price R$ #{product.price}

          if product.stock > 0
            .stock-value Em estoque: #{product.stock}
          else
            .stock-value(style="background: #fee2e2; color: #dc2626; border-color: #fecaca;") Esgotado

          if product.description
            .product-description
              h3 Descrição:
              p= product.description

          form(method='POST', action='/carrinho/add/#{session.usuario.id}/#{product.id}')
            input(type='hidden', name='productId', value=product.id)
            
            .product-actions
              if product.stock > 0
                button.btn-buy(type='submit') 
                  span.cart-icon 🛒
                  | Adicionar ao carrinho
              else
                button.btn(type='button', disabled, style="background: #e5e7eb; color: #9ca3af; cursor: not-allowed;") Indisponível

          .action-buttons(style="margin-top: 1.5rem;")
            a.btn-cart(href='/products') 
              | ← Voltar
            if session.usuario && session.usuario.funcao === 'admin'
              a.btn-edit(href='/products/#{product.id}/edit') 
                span.btn-icon ✏️
                | Editar
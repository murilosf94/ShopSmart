extends ../layout

block content
  h2 Editar Produto
  form(method='POST', action=`/products/${product.id}?_method=PUT`, enctype="multipart/form-data")
    
    input(type="hidden", name="currentImageUrl", value=product.imageUrl)


    label Nome:
    input(type='text', name='name', value=product.name, required)
    br
    label Descrição:
    textarea(name='description')= product.description
    br
    label Preço:
    input(type='number', step='0.01', name='price', value=product.price, required)
    br
    label Estoque:
    input(type='number', name='stock', value=product.stock)
    label Imagem (novo upload opcional):
    input(type="file", name="image", accept="image/*")

    br
    button(type='submit') Salvar

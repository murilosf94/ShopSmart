extends layout 

block content
  .products-hero
    .hero-overlay
    .hero-content
      .hero-text
        h1 Nossos Produtos
        p.hero-description Descubra nossa seleção exclusiva de produtos

  .products-section
    .container
      .products-layout
        .products-grid
          each p in products
            .product-card
              .product-image-container
                if p.imageUrl
                  a.product-link(href="/products/#{p.id}")
                    img.product-image(src=p.imageUrl, alt=p.name)
                else
                  a.product-link(href="/products/#{p.id}")
                    .product-placeholder
                      .placeholder-icon 📦
                      span Sem imagem

              .product-content
                h3.product-title #{p.name}
                .product-price R$ #{p.price}
                
                .product-actions
                  a.btn-buy(href="/products/#{p.id}") Ver Detalhes
                  if session.usuario
                    a.btn-cart(href="/carrinho/add/#{session.usuario.id}/#{p.id}")
                      span.cart-icon 🛒
                      | Adicionar

        .products-sidebar
          .sidebar-card
            .sidebar-header
              h3 Categorias
            .sidebar-content
              .category-list
                a.category-item(href="/categorias/moda")
                  span.category-icon 👕
                  | Moda
                a.category-item(href="/categorias/eletronicos")
                  span.category-icon 💻
                  | Eletrônicos
                a.category-item(href="/categorias/esporte")
                  span.category-icon &#x26BD
                  | Esportes
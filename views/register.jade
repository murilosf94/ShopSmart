extends layout

block content
  .login-container
    .login-card
      // Logo/Header
      .login-header
        .logo-circle S
        h1 Bem-vindo ao ShopSmart!
        p Faça seu cadastro e em poucos instantes aproveite todos nossos benefícios

      // Login Form
      .login-form-card
        form#loginForm(method="post" action="/login")
          // Username Field
          .form-group
            label(for="usuario") Usuário
            .input-container
              span.input-icon
                img(src="../images/icons/do-utilizador.png", alt="")
              input#usuario(
                type="text" 
                name="usuario" 
                required 
                placeholder="Digite seu usuário"
              )

          // Password Field
          .form-group
            label(for="senha") Senha
            .input-container
              span.input-icon
                img(src="../images/icons/bloquear-alt.png", alt="")
              input#senha(
                type="password" 
                name="senha" 
                required 
                placeholder="Digite sua senha"
              )

          // Submit Button
          button.submit-btn(type="submit") Entrar

          // Social Login
          .social-login
            .divider
              span Ou continue com
              .divider-line

            .social-buttons
              button.social-btn(type="button")
                span 📧
                | Google
              
              button.social-btn(type="button")
                span 📱
                | Facebook

        // Login Link
        .login-link
          p
            | Já tem uma conta? 
            a(href="/login") Faça login aqui

  script(src="/js/login.js")
  link(rel="stylesheet" href="../stylesheets/login.css")




extends layout
block content
    .postagem
        h1.corpadrao Cadastrar novo usuário
        if error
            p(style="color: red") #{error}
        form(action="/register", method="post")
            div
            label(for="usuario") Usuário:
            input(type="text", name="usuario", id="usuario", required)
            div
            label(for="senha") Senha:
            input(type="password", name="senha", id="senha", required)
            div
            label(for="funcao") Função:
            select(name="funcao", id="funcao")
                option(value="user") user
                option(value="admin") admin
            div
            button(type="submit") Cadastrar
        p
            a(href="/login") Já tem conta? Faça login

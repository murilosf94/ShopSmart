extends layout 

block content
  .products-hero
    .container
      h1.admin-title Compra Realizada com Sucesso!
  
  .products-section
    .container
      .admin-header
        h2.admin-title Detalhes da sua compra
        p Obrigado por comprar conosco! Seus produtos serão processados em breve.
        
        .products-sidebar
          .sidebar-card
            .sidebar-header
              h3 Resumo da Compra
            
            .sidebar-content
              .category-list
                .category-item
                  .category-icon 📋
                  | Status: Confirmado
                
                .category-item
                  .category-icon 🚚
                  | Entrega: 5-7 dias úteis
                
                .category-item
                  .category-icon 📧
                  | Email de confirmação enviado
              
              .product-actions(style="margin-top: 1rem;")
                a.btn-buy(href="/") Voltar à Loja
                a.btn-cart(href="/carrinho") Ver Carrinho
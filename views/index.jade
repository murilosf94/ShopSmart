extends layout

block content
  // Hero Section
  section.hero-section
    .hero-overlay
    .hero-content
      .hero-text
        h1 Bem-vindo à ShopSmart!
        p.hero-subtitle Sua experiência de compra é nossa prioridade!
        p.hero-description Descubra uma seleção incrível de produtos, desde moda até eletrônicos, com ofertas imperdíveis.
        a.cta-button(href="/nossosprodutos")
          | Explorar Produtos
          span.cta-arrow →
      .hero-img.intense-glow
        

  // Features Section
  section.features-section
    .container
      .features-grid
        .feature-item
          .feature-icon 🛡️
          h3 Pagamento Seguro
          p 100% protegido
        
        .feature-item
          .feature-icon 📈
          h3 Entrega Rápida
          p Em todo o Brasil
        
        .feature-item
          .feature-icon 👥
          h3 Suporte 24/7
          p Sempre disponível
        
        .feature-item
          .feature-icon ⭐
          h3 Qualidade Premium
          p Produtos selecionados

  // Categories Section
  section.categories-section
    .container
      h2.section-title Nossas Categorias
      
      .categories-grid
        a.category-card(href="/categorias/roupas")
          .category-header
            img(src="../images/categories/moda.png", alt="")
          .category-content
            h3 Moda
            p As melhores roupas do mercado!!!
            .category-link
              | Ver produtos 
              span.category-arrow →

        a.category-card(href="/categorias/eletronicos")
          .category-header
            img(src="../images/categories/eletronico.png", alt="")
          .category-content
            h3 Eletrônicos
            p Os gadgets mais modernos chegaram! Visite nossa seção de tecnologia e eletrônicos e fique por dentro.
            .category-link
              | Ver produtos 
              span.category-arrow →

        a.category-card(href="/categorias/esportes")
          .category-header
            img(src="../images/categories/esportes.png", alt="")
          .category-content
            h3 Esportes
            p Os melhores equipamentos para otimizar seus treinos!
            .category-link
              | Ver produtos 
              span.category-arrow →

  // Offers Section
  section.offers-section
    .container.offers-container
      .offers-card
        h2.offers-title 🎉 Nossas Ofertas Especiais
        
        .offers-grid
          .offer-item.offer-discounts
            .offer-icon %
            div
              h4 Ofertas imperdíveis
              p Para você aproveitar!

          .offer-item.offer-shipping
            .offer-icon 🚚
            div
              h4 Frete grátis
              p Em compras acima de R$ 200,00

          .offer-item.offer-new-customers
            .offer-icon ⭐
            div
              h4 Novos clientes
              p Descontos especiais

          .offer-item.offer-fifty-off
            .offer-icon 50
            div
              h4 Até 50% OFF
              p Em produtos selecionados